# ========== StaticDrop 环境变量 ==========

# --- 全局 ---
# 对外公开的基础 URL（用于生成部署访问链接）
PUBLIC_BASE_URL=http://localhost:8080
# Optional comma-separated origins for direct browser API clients.
CORS_ORIGINS=

# --- FastAPI 鉴权 ---
# 全局部署 token，Web 控制台和 API 共用
DEPLOY_TOKEN=change-me-to-a-random-string

# --- 构建源 ---
# 基础镜像前缀。留空表示 Docker Hub，例如：
# IMAGE_REGISTRY=docker.m.daocloud.io/library/
IMAGE_REGISTRY=
# npm / PyPI 默认使用官方源；大陆环境可替换为可访问的国内镜像。
NPM_REGISTRY=https://registry.npmjs.org
PYPI_INDEX_URL=https://pypi.org/simple

# --- 文件限制（字节）---
MAX_ZIP_SIZE=104857600       # 100MB
MAX_TOTAL_SIZE=524288000     # 500MB
MAX_FILE_SIZE=52428800       # 50MB
MAX_FILE_COUNT=5000
MAX_STORAGE_SIZE=5368709120  # 5GB deployed content
MIN_FREE_SPACE=67108864      # 64MB safety reserve

# --- 路径（容器内，通常不需要改）---
DATA_DIR=/data
DB_PATH=/data/db/staticdrop.db
DEPLOYMENTS_DIR=/data/deployments
