# ========== StaticDrop 环境变量 ==========

# --- 全局 ---
# 对外公开的基础 URL（用于生成部署访问链接）
PUBLIC_BASE_URL=http://localhost:8080
PUBLIC_DOMAIN=
# Optional comma-separated origins for direct browser API clients.
CORS_ORIGINS=

# --- 可选公网域名与 HTTPS ---
# disabled：仅通过 IP/端口访问；platform：启用 Caddy 自动 HTTPS。
DOMAIN_MODE=disabled
PUBLIC_DOMAIN=
# DOMAIN_MODE=platform 时改为 https://你的域名
NGINX_BIND=0.0.0.0
HTTP_PORT=80
HTTPS_PORT=443

# --- FastAPI 鉴权 ---
# 全局部署 token，Web 控制台和 API 共用
DEPLOY_TOKEN=change-me-to-a-random-string

# --- 用户模式（默认 token 兼容模式）---
# 一键部署默认启用用户注册；改为 token 可关闭注册并只使用 DEPLOY_TOKEN。
AUTH_MODE=users
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-random-password
SESSION_TTL_DAYS=14
GITHUB_TOKEN=
# Optional Cloudflare DNS automation. Use a scoped API token with DNS edit access.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=example.com
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4

# --- 构建源 ---
# 基础镜像前缀。留空表示 Docker Hub，例如：
# IMAGE_REGISTRY=docker.m.daocloud.io/library/
IMAGE_REGISTRY=
# npm / PyPI 默认使用官方源；大陆环境可替换为可访问的国内镜像。
NPM_REGISTRY=https://registry.npmjs.org
PYPI_INDEX_URL=https://pypi.org/simple

# --- 文件限制（字节）---
MAX_ZIP_SIZE=104857600       # 100MB
MAX_TOTAL_SIZE=524288000     # 500MB
MAX_FILE_SIZE=52428800       # 50MB
MAX_FILE_COUNT=5000
MAX_STORAGE_SIZE=5368709120  # 5GB deployed content
MIN_FREE_SPACE=67108864      # 64MB safety reserve
MAX_VERSIONS_PER_PROJECT=10  # Keep current version plus recent history
AUTO_CLEANUP_ENABLED=true

# --- 路径（容器内，通常不需要改）---
DATA_DIR=/data
DB_PATH=/data/db/staticdrop.db
DEPLOYMENTS_DIR=/data/deployments
